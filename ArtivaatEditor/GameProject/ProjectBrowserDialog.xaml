<Window x:Class="ArtivaatEditor.GameProject.ProjectBrowserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ArtivaatEditor.GameProject"
        mc:Ignorable="d" ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        Title="ProjectBrowserDialog" Height="450" Width="800">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top buttons -->
        <StackPanel Grid.Row="0"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Margin="20">

            <ToggleButton Content="Open Project"
                      FontSize="32"/>

            <ToggleButton Content="Create Project"
                      FontSize="32"
                      Margin="30,0,0,0"/>

        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" >
           <!-- Main content -->
            <Border Grid.Row="1" Background="LightBlue" >
              <TextBlock FontSize="72" Text="Open Project"></TextBlock>
            </Border>
            <Border Grid.Row="1" Background="LightGreen">
              <TextBlock FontSize="72" Text="Create Project"></TextBlock>
            </Border>
        </StackPanel>
    </Grid>
</Window>
